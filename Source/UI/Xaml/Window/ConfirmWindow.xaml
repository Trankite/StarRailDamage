<local:ScopedWindow
    x:Class="StarRailDamage.Source.UI.Xaml.Window.ConfirmWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:StarRailDamage.Source.UI.Xaml.Control.Panel"
    Title="{Binding WindowTitle}" Height="400" Width="600" Topmost="True"
    WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <local:ScopedWindow.DataContext>
        <Binding RelativeSource="{RelativeSource Self}"/>
    </local:ScopedWindow.DataContext>

    <local:ScopedWindow.Background>
        <ImageBrush ImageSource="{StaticResource Image_Backgroup}"/>
    </local:ScopedWindow.Background>
    
    <Grid>

    </Grid>
</local:ScopedWindow>