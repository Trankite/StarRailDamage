<UserControl
    x:Class="StarRailDamage.Source.UI.Xaml.View.FieldEntrySpan"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:StarRailDamage.Source.UI.Xaml.View"
    xmlns:suxc="clr-namespace:StarRailDamage.Source.UI.Xaml.Control"
    xmlns:suxcp="clr-namespace:StarRailDamage.Source.UI.Xaml.Control.Panel"
    Focusable="True" FocusVisualStyle="{x:Null}">
    <UserControl.Template>
        <ControlTemplate TargetType="{x:Type UserControl}">
            <Border CornerRadius="15" Background="{Binding Background,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}">
                <Grid Width="200" Height="30" Margin="5,0,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid.Resources>
                        <Style TargetType="{x:Type suxc:ScopedTextBlock}">
                            <Setter Property="Foreground" Value="{Binding Foreground,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="FontSize" Value="{Binding FontSize,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="FontWeight" Value="{Binding FontWeight,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="TipOnlyTrim" Value="True"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>

                        <Style TargetType="{x:Type suxc:ScopedTextBox}">
                            <Setter Property="Foreground" Value="{Binding Foreground,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="Background" Value="{Binding BorderBrush,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="FocusBrush" Value="{Binding FocusBrush,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="FontSize" Value="{Binding FontSize,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="FontWeight" Value="{Binding FontWeight,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="CornerRadius" Value="10"/>
                            <Setter Property="Padding" Value="0,0,5,0"/>
                        </Style>
                    </Grid.Resources>

                    <Image Grid.Column="0" Width="25" Height="25" Source="{Binding Model.Icon,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}" VerticalAlignment="Center"/>

                    <suxcp:ScopedViewBox Grid.Column="1" MaxWidth="65">
                        <suxc:ScopedTextBlock Text="{Binding  Model.Title,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}" TipText="{Binding Text,RelativeSource={RelativeSource Self}}"/>
                    </suxcp:ScopedViewBox>

                    <suxc:ScopedTextBox Grid.Column="3" Width="80" Text="{Binding Model.Text,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}},Mode=TwoWay,Converter={StaticResource DoubleParser},StringFormat={}{0:0.0;0.0;0}}" IsEnabled="{Binding ReadOnly,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}},Converter={StaticResource BooleanToggle}}" TextAlignment="Right" InputMethod.IsInputMethodEnabled="False" GotFocus="TextBoxGotFocus" KeyDown="TextBoxKeyDown"/>

                    <suxcp:ScopedViewBox Grid.Column="4" Width="20">
                        <suxc:ScopedTextBlock Text="{Binding Model.Unit,RelativeSource={RelativeSource AncestorType={x:Type local:FieldEntrySpan}}}" TipText="{Binding Text,RelativeSource={RelativeSource Self}}" TextAlignment="Center"/>
                    </suxcp:ScopedViewBox>
                </Grid>
            </Border>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>