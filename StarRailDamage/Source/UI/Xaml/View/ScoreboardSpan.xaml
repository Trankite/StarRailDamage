<UserControl
    x:Class="StarRailDamage.Source.UI.Xaml.View.ScoreboardSpan"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:StarRailDamage.Source.UI.Xaml.View"
    xmlns:suxc="clr-namespace:StarRailDamage.Source.UI.Xaml.Control">
    <UserControl.Template>
        <ControlTemplate TargetType="{x:Type UserControl}">
            <Border CornerRadius="15" Background="{TemplateBinding Background}">
                <Grid Margin="10">
                    <Grid.Resources>
                        <Style TargetType="{x:Type suxc:ScopedTextBlock}">
                            <Setter Property="Foreground" Value="{Binding Foreground,RelativeSource={RelativeSource AncestorType={x:Type local:ScoreboardSpan}}}"/>
                            <Setter Property="FontSize" Value="{Binding FontSize,RelativeSource={RelativeSource AncestorType={x:Type local:ScoreboardSpan}}}"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </Grid.Resources>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <suxc:ScopedTextBlock Grid.Row="0" Text="{Binding Model.Title,RelativeSource={RelativeSource AncestorType={x:Type local:ScoreboardSpan}}}" TipText="{Binding Text,RelativeSource={RelativeSource Self}}" TipOnlyTrim="True" TextTrimming="CharacterEllipsis" FontWeight="Bold"/>
                    <suxc:ScopedTextBlock Grid.Row="2" Text="{Binding Model.Value,RelativeSource={RelativeSource AncestorType={x:Type local:ScoreboardSpan}},StringFormat={}{0:F0}}"/>
                    <suxc:ScopedTextBlock Grid.Row="4" Text="{Binding Model.Percent,RelativeSource={RelativeSource AncestorType={x:Type local:ScoreboardSpan}},StringFormat={}{0:+0.#%;-0.#%;0;}}" Foreground="{Binding TempBrush,RelativeSource={RelativeSource AncestorType={x:Type local:ScoreboardSpan}}}" FontSize="{Binding DropFontSize,RelativeSource={RelativeSource AncestorType={x:Type local:ScoreboardSpan}}}">
                        <suxc:ScopedTextBlock.Style>
                            <Style TargetType="{x:Type suxc:ScopedTextBlock}" BasedOn="{StaticResource {x:Type suxc:ScopedTextBlock}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text,RelativeSource={RelativeSource Self}}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </suxc:ScopedTextBlock.Style>
                    </suxc:ScopedTextBlock>
                </Grid>
            </Border>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>